{
  "appId": "be.visiontree.elevather",
  "appName": "Elevather",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["app.elevather.eu"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": false,
      "backgroundColor": "#f0f8fb",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    }
  }
}